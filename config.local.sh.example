#!/bin/bash
# 本地配置文件 — 按 GPU 类型选择预设，然后按需微调
#
# 快速开始（二选一）:
#   cp config.a800.sh config.local.sh      # A800 80GB
#   cp config.rtx6000.sh config.local.sh   # RTX PRO 6000 96GB
#
# 该文件会被 run_phase_c.sh 自动 source，覆盖默认值
# config.local.sh 已加入 .gitignore，不会提交到仓库
#
# ── 也可以手动配置 ──

# 模型路径
SIMULATOR_MODEL=/root/autodl-tmp/models/Simulation_LLM_google_3B
SEARCH_ENGINE=google

# 显存分配
# SIMULATOR_MEM_FRACTION=0.2
# ROLLOUT_GPU_MEM_UTIL=0.4

# Batch size
# TRAIN_BATCH_SIZE=64
# PPO_MICRO_BATCH_SIZE=16
# LOG_PROB_MICRO_BATCH_SIZE=16

# vLLM 推理策略
# ENFORCE_EAGER=True        # True=省显存 False=CUDA图加速
# FREE_CACHE_ENGINE=True    # True=训练时释放KV cache False=保留提速
